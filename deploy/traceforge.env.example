NODE_ENV=production
PORT=4034
HOST=127.0.0.1
TRACEFORGE_ENABLE_CODEX=0
TRACEFORGE_DB=/var/lib/traceforge/traceforge.sqlite
TRACEFORGE_ALLOWED_ORIGINS=https://traceforge.axiqo.xyz
TRACEFORGE_MIGRATION_RATE_MAX=10
TRACEFORGE_MIGRATION_RATE_WINDOW_MS=60000
TRACEFORGE_MIGRATION_MAX_CONCURRENT=2
TRACEFORGE_MIGRATION_MAX_QUEUED=4
TRACEFORGE_RETENTION_MAX_COMPLETED_JOBS=100
TRACEFORGE_RETENTION_MAX_AGE_HOURS=72
