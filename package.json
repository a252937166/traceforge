{
  "name": "traceforge",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-bounded workflow modernization with differential proof.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm --filter @traceforge/api dev\" \"pnpm --filter @traceforge/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "acceptance:api": "node scripts/acceptance-api.mjs",
    "acceptance:ui": "node scripts/acceptance-ui.mjs",
    "acceptance:repeat": "node scripts/acceptance-repeat.mjs",
    "acceptance:all": "pnpm check && pnpm acceptance:api -- --mode baseline && pnpm acceptance:api -- --mode mutation && pnpm acceptance:ui && pnpm acceptance:repeat -- --runs 10",
    "release:package": "node scripts/package-release.mjs",
    "capture:showcase": "node scripts/capture-showcase.mjs",
    "proof:verify": "pnpm --filter @traceforge/api proof:verify"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "concurrently": "^9.2.1"
  }
}
